# ============================================================
# BetaZen G-Map Scraper — Node.js CLI Scraper (direct MongoDB)
# ============================================================
#
# As of v1.6.0 the CLI talks straight to MongoDB — there is no
# longer an HTTP backend in the path. Every scraper device needs
# its own connection string in this file.
#
# File layout (only .env.example is committed to git):
#   .env          — your working config (gitignored)
#   .env.example  — this template (tracked in git)
#
# Copy this file to `.env` to get started.
# ============================================================

# local | dev | prod — picks which MongoDB URI below gets used
APP_STATE=local

# MongoDB URI used when APP_STATE=local (your machine, local mongod)
LOCAL_MONGODB_URI=mongodb://127.0.0.1:27017/gmap-scrap

# MongoDB URI used when APP_STATE=dev (your machine, remote dev cluster)
DEV_MONGODB_URI=mongodb://127.0.0.1:27017/gmap-scrap

# MongoDB URI used when APP_STATE=prod (deployed production cluster)
# For Atlas use the mongodb+srv:// form. Include the database name
# at the end (e.g. .../gmap-scrap?retryWrites=true&w=majority).
PROD_MONGODB_URI=mongodb+srv://user:password@cluster0.example.mongodb.net/gmap-scrap?retryWrites=true&w=majority

# Playwright browser mode: true = headless, false = show browser window
HEADLESS=false
