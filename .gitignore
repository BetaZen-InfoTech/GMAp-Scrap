# ============================================================
# BetaZen G-Map Scraper — Root .gitignore
# ============================================================

# ── Dependencies ──────────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Environment files ────────────────────────────────────────
# Only ignore .env (device-specific secrets)
# .env.local, .env.dev, .env.prod are committed (shared configs)
.env
!.env.local
!.env.dev
!.env.prod
!.env.example

# ── Build output ─────────────────────────────────────────────
dist/
dist-electron/
release/
out/
build/

# ── Vite ─────────────────────────────────────────────────────
*.local
!.env.local

# ── OS files ─────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Archives ─────────────────────────────────────────────────
*.zip
*.rar
*.7z
*.tar.gz

# ── Upload / Excel output ───────────────────────────────────
uploads/
upload/
frontend-nodejs/excel/

# ── Session artifacts ────────────────────────────────────────
CONVERSATION_SUMMARY.md

# ── Claude Code (settings.local.json is device-specific) ────
.claude/settings.local.json
