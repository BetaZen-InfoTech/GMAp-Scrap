# ============================================================
# BetaZen G-Map Scraper — Frontend (Electron scraper)
# ============================================================
#
# File layout (only .env.example is committed to git):
#   .env          — your working config (gitignored)
#   .env.example  — this template (tracked in git)
#
# Copy this file to `.env` to get started.
# ============================================================

# local | dev | prod — picks which API URL below gets used
APP_STATE=local

# API URL used when APP_STATE=local (your machine, local backend)
LOCAL_API_URL=http://127.0.0.1:5000

# API URL used when APP_STATE=dev (your machine, remote backend)
DEV_API_URL=http://127.0.0.1:5000

# API URL used when APP_STATE=prod (deployed production server)
PROD_API_URL=https://example.com
