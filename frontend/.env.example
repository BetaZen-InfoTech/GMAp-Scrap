# ============================================================
# BetaZen G-Map Scraper — Frontend Environment Configuration
# ============================================================

# App state: local | dev | prod
# local → http://127.0.0.1:5000           (your machine, local backend)
# dev   → http://127.0.0.1:5000           (your machine, remote backend)
# prod  → remote production server         (https://gmap-scrap-backend-api.betazeninfotech.com)
APP_STATE=prod

# API URLs per state
LOCAL_API_URL=http://127.0.0.1:5000
DEV_API_URL=http://127.0.0.1:5000
PROD_API_URL=https://gmap-scrap-backend-api.betazeninfotech.com
