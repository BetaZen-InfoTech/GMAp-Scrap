{
  "name": "google-maps-scraper",
  "version": "1.2.0",
  "description": "Google Maps Scraper Desktop App",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "setup:browsers": "node -e \"require('child_process').spawnSync(process.execPath,['node_modules/playwright/cli.js','install','chromium'],{stdio:'inherit',env:{...process.env,PLAYWRIGHT_BROWSERS_PATH:'0'}})\"",
    "prebuild": "npm run setup:browsers",
    "build": "vite build && electron-builder",
    "build:portable": "vite build && electron-builder --win portable",
    "build:installer": "vite build && electron-builder --win nsis",
    "build:all": "vite build && electron-builder --win nsis portable",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "BetaZen InfoTech",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^9.0.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.5",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1",
    "zustand": "^4.5.7"
  },
  "build": {
    "appId": "com.betazen.mapscraper",
    "productName": "Google Maps Scraper",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/playwright/.local-browsers",
        "to": "playwright-browsers",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ]
  }
}
