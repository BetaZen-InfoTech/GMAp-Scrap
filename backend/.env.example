# ============================================================
# BetaZen G-Map Scraper — Backend Environment Configuration
# ============================================================
#
# Files layout:
#   .env         — device-specific overrides (gitignored, highest precedence)
#   .env.local   — committed defaults for APP_STATE=local
#   .env.dev     — committed defaults for APP_STATE=dev
#   .env.prod    — committed defaults for APP_STATE=prod
#
# APP_STATE picks which .env.<state> is loaded. `.env` overrides everything.
# ============================================================

# Server port
PORT=5000

# App state: local | dev | prod
# local → local backend + remote MongoDB (for local testing)
# dev   → local backend + remote MongoDB (same as local, separate for future)
# prod  → deployed backend + remote MongoDB
APP_STATE=dev

# MongoDB connection strings per state
LOCAL_MONGODB_URI=mongodb://BetaZen:BetaZen2023@mongo.betazeninfotech.com:27017/g_map_scrapping?authSource=g_map_scrapping
DEV_MONGODB_URI=mongodb://BetaZen:BetaZen2023@mongo.betazeninfotech.com:27017/g_map_scrapping?authSource=g_map_scrapping
PROD_MONGODB_URI=mongodb://BetaZen:BetaZen2023@mongo.betazeninfotech.com:27017/g_map_scrapping?authSource=g_map_scrapping

# The actual URI used at runtime — set this per .env.<state> file
MONGODB_URI=mongodb://BetaZen:BetaZen2023@mongo.betazeninfotech.com:27017/g_map_scrapping?authSource=g_map_scrapping

# API URLs per state (used by frontend Electron apps)
LOCAL_API_URL=http://127.0.0.1:5000
DEV_API_URL=http://127.0.0.1:5000
PROD_API_URL=https://gmap-scrap-backend-api.betazeninfotech.com

# Node environment
NODE_ENV=development
