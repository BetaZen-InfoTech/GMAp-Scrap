# ============================================================
# BetaZen G-Map Scraper — Backend Environment Configuration
# ============================================================
#
# File layout (only .env.example is committed to git):
#   .env          — your working config (gitignored)
#   .env.local    — optional: APP_STATE=local overrides (gitignored)
#   .env.dev      — optional: APP_STATE=dev overrides (gitignored)
#   .env.prod     — optional: APP_STATE=prod overrides (gitignored)
#   .env.example  — this template (tracked in git)
#
# Loader (src/config/loadEnv.js) reads `.env` first, then layers
# an optional `.env.<APP_STATE>` on top with override:false.
#
# MONGODB_URI resolution order:
#   1. if MONGODB_URI is set explicitly, use it
#   2. else use the <STATE>_MONGODB_URI matching APP_STATE
#
# Copy this file to `.env` and fill in real values to get started.
# ============================================================

# ── Runtime ──────────────────────────────────────────────────

# Port the Express server listens on
PORT=5000

# local | dev | prod
APP_STATE=local

# development | production
NODE_ENV=development

# ── Database (per-state URIs; loader picks one by APP_STATE) ─

# MongoDB connection string used when APP_STATE=local
LOCAL_MONGODB_URI=mongodb://<user>:<password>@<host>:27017/<db>?authSource=<db>

# MongoDB connection string used when APP_STATE=dev
DEV_MONGODB_URI=mongodb://<user>:<password>@<host>:27017/<db>?authSource=<db>

# MongoDB connection string used when APP_STATE=prod
PROD_MONGODB_URI=mongodb://<user>:<password>@<host>:27017/<db>?authSource=<db>

# Optional — set to override the state-specific URI above
# MONGODB_URI=

# ── Admin auth ───────────────────────────────────────────────

# Password for the admin dashboard login endpoint (POST /api/admin/login).
# Use a strong, unique value in every environment.
ADMIN_PASSWORD=change-me
